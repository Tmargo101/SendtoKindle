STK_USERS_CONFIG_PATH=/app/config/users.yaml
STK_SMTP_HOST=smtp.example.com
STK_SMTP_PORT=587
STK_SMTP_USERNAME=mailer
STK_SMTP_PASSWORD=replace-me
STK_SMTP_SENDER=send-to-kindle@example.com
STK_BROWSER_FETCH_ENABLED=true
STK_BROWSER_FETCH_TIMEOUT_SECONDS=30
# Optional for image-based deployments that want to override the default GHCR tag.
# STK_IMAGE=ghcr.io/tmargo101/send-to-kindle:latest
