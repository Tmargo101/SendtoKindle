STK_BASE_DIR=/app
STK_DATA_DIR=/app/data
STK_ARTIFACTS_DIR=/app/artifacts
STK_DATABASE_PATH=/app/data/send_to_kindle.db
STK_USERS_CONFIG_PATH=/app/config/users.yaml
STK_SMTP_HOST=smtp.example.com
STK_SMTP_PORT=587
STK_SMTP_USERNAME=mailer
STK_SMTP_PASSWORD=replace-me
STK_SMTP_SENDER=send-to-kindle@example.com
STK_SMTP_USE_TLS=true
STK_REQUEST_TIMEOUT_SECONDS=20
STK_MAX_REDIRECTS=5
STK_WORKER_POLL_INTERVAL_SECONDS=2
STK_WORKER_MAX_RETRIES=3
STK_RETRY_BACKOFF_SECONDS=30
STK_RETENTION_HOURS=24
STK_LOG_LEVEL=INFO
